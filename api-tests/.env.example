# Copy to .env and fill in real values.
# .env is gitignored; .env.example is committed as a template.

# --- Internal services ---
BACKEND_URL=http://localhost:8000
HEARTBEAT_URL=http://localhost:8080

# Test account (used by backend/auth.http to obtain AUTH_TOKEN)
TEST_USERNAME=
TEST_PASSWORD=

# Bearer token returned by login. Refresh via backend/auth.http.
AUTH_TOKEN=

# --- Test device (for pad/heartbeat endpoints) ---
# device_id=14884 is the shared UI test device (see memory).
TEST_DEVICE_ID=14884
TEST_DEVICE_SN=
TEST_DEVICE_MAC=

# --- Google Calendar API ---
# OAuth2 access token (short-lived). Obtain via OAuth flow or copy from a SyncedCalendar row.
GOOGLE_OAUTH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# --- Microsoft Graph API ---
MS_GRAPH_TOKEN=
MS_USER_ID=me

# --- iCloud (CalDAV) ---
# Apple ID + app-specific password (NOT your Apple ID password).
ICLOUD_USERNAME=
ICLOUD_APP_PASSWORD=
