# iCloud Calendar uses CalDAV (not a REST API).
# Auth: HTTP Basic with Apple ID + app-specific password.
#   Generate one at https://account.apple.com/account/manage → Sign-In and Security → App-Specific Passwords.
#
# Server discovery flow:
#   1. PROPFIND /.well-known/caldav at caldav.icloud.com → redirects to per-user host
#   2. PROPFIND user's principal URL → calendar-home-set
#   3. PROPFIND calendar-home-set → list of calendar collections
#   4. REPORT on a calendar → events (VEVENT iCalendar data)
#
# `.http` format supports arbitrary methods including CalDAV's PROPFIND/REPORT.
# Many simple HTTP runners do NOT, so for these requests `curl` is the reliable path.

### Step 1: discover principal URL
PROPFIND https://caldav.icloud.com/.well-known/caldav
Authorization: Basic {{ICLOUD_USERNAME}}:{{ICLOUD_APP_PASSWORD}}
Depth: 0
Content-Type: application/xml

<?xml version="1.0" encoding="utf-8"?>
<d:propfind xmlns:d="DAV:">
  <d:prop>
    <d:current-user-principal/>
  </d:prop>
</d:propfind>

### Step 2: list calendar home (replace :principalUrl from step 1 response)
PROPFIND https://caldav.icloud.com/PRINCIPAL_PATH/
Authorization: Basic {{ICLOUD_USERNAME}}:{{ICLOUD_APP_PASSWORD}}
Depth: 0
Content-Type: application/xml

<?xml version="1.0" encoding="utf-8"?>
<d:propfind xmlns:d="DAV:" xmlns:c="urn:ietf:params:xml:ns:caldav">
  <d:prop>
    <c:calendar-home-set/>
  </d:prop>
</d:propfind>

### Step 3: list calendars under calendar-home-set
PROPFIND https://caldav.icloud.com/CALENDAR_HOME_PATH/
Authorization: Basic {{ICLOUD_USERNAME}}:{{ICLOUD_APP_PASSWORD}}
Depth: 1
Content-Type: application/xml

<?xml version="1.0" encoding="utf-8"?>
<d:propfind xmlns:d="DAV:" xmlns:c="urn:ietf:params:xml:ns:caldav">
  <d:prop>
    <d:displayname/>
    <d:resourcetype/>
    <c:supported-calendar-component-set/>
  </d:prop>
</d:propfind>

### Step 4: REPORT events in a calendar (date range)
REPORT https://caldav.icloud.com/CALENDAR_PATH/
Authorization: Basic {{ICLOUD_USERNAME}}:{{ICLOUD_APP_PASSWORD}}
Depth: 1
Content-Type: application/xml

<?xml version="1.0" encoding="utf-8"?>
<c:calendar-query xmlns:d="DAV:" xmlns:c="urn:ietf:params:xml:ns:caldav">
  <d:prop>
    <d:getetag/>
    <c:calendar-data/>
  </d:prop>
  <c:filter>
    <c:comp-filter name="VCALENDAR">
      <c:comp-filter name="VEVENT">
        <c:time-range start="20260425T000000Z" end="20260525T000000Z"/>
      </c:comp-filter>
    </c:comp-filter>
  </c:filter>
</c:calendar-query>
