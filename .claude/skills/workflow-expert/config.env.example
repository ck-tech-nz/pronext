# workflow-expert skill — personal tokens (copy to config.env and fill in).
# config.env is gitignored; do not commit real tokens.

# Sentry (required for `s<N>` / sentry#<N> source)
# Get from: https://sentry.io/settings/account/api/auth-tokens/
SENTRY_TOKEN=
SENTRY_ORG=pronext

# DevTrakr (required for `d<N>` / devtrakr#<N> source)
DEVTRAKR_BASE_URL=
DEVTRAKR_TOKEN=

# Notification webhook(s) — optional until notify.sh is wired
# SLACK_WEBHOOK_URL=
# FEISHU_WEBHOOK_URL=
