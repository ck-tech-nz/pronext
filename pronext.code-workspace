{
  "folders": [
    {
      "path": ".",
    },
  ],
  "settings": {
    "editor.fontSize": 16,
    "files.exclude": {
      "**/.adal": true,
      "**/.agent": true,
      "**/.agents": true,
      "**/.augment": true,
      "**/.cline": true,
      "**/.codebuddy": true,
      "**/.commandcode": true,
      "**/.continue": true,
      "**/.crush": true,
      "**/.cursor": true,
      "**/.factory": true,
      "**/.goose": true,
      "**/.iflow": true,
      "**/.junie": true,
      "**/.kilocode": true,
      "**/.kiro": true,
      "**/.kode": true,
      "**/.mcpjam": true,
      "**/.mux": true,
      "**/.neovate": true,
      "**/.openhands": true,
      "**/.pi": true,
      "**/.pochi": true,
      "**/.qoder": true,
      "**/.qwen": true,
      "**/.roo": true,
      "**/.trae": true,
      "**/.vibe": true,
      "**/.windsurf": true,
      "**/.zencoder": true,
    },
    "chatgpt.openOnStartup": false,
    "workbench.colorTheme": "Dark 2026",
  },
  "launch": {
    "version": "0.2.0",
    "compounds": [
      {
        "name": "Full Stack",
        "configurations": ["backend", "npm: dev", "Flutter"],
        "stopAll": true,
      },
    ],
    "configurations": [
      {
        "name": "backend",
        "type": "debugpy",
        "request": "launch",
        "args": ["runserver", "0.0.0.0:8000"],
        "django": true,
        "autoStartBrowser": false,
        "justMyCode": true,
        "program": "${workspaceFolder}/backend/manage.py",
      },
      {
        "type": "node",
        "request": "launch",
        "name": "npm: dev",
        "runtimeExecutable": "npm",
        "runtimeArgs": ["run", "dev"],
        "cwd": "${workspaceFolder}/h5",
        "console": "integratedTerminal",
      },
      {
        "name": "Flutter",
        "type": "dart",
        "request": "launch",
        "cwd": "${workspaceFolder}/app",
        "program": "lib/main.dart",
      },
      {
        "name": "Celery Worker",
        "type": "debugpy",
        "request": "launch",
        "module": "celery",
        "args": ["-A", "pronext_server", "worker", "-l", "info"],
        "justMyCode": true,
        "cwd": "${workspaceFolder}/backend",
        "console": "integratedTerminal",
      },
    ],
  },
}
